# ─────────────────────────────────────────────────────────────────────────────
# Tech Mentor ERP & POS — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in all values marked REQUIRED
# 3. NEVER commit .env to source control
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# REQUIRED. MySQL connection string.
# Hostinger:  mysql://DB_USER:DB_PASSWORD@HOST:3306/DB_NAME
DATABASE_URL=mysql://user:password@localhost:3306/techmentor

# Optional. Dev-only override that takes precedence over DATABASE_URL. The Replit
# preview uses this to point at the local MariaDB. Leave unset in production.
# MYSQL_URL=mysql://root@127.0.0.1:3306/erp

# Optional. Set to "true" only when connecting to a MySQL host over a public
# endpoint that requires TLS. Not needed for localhost or internal networking.
# DATABASE_SSL=true

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# REQUIRED. Secret used to sign JWT tokens. Use a minimum 64-character hex string.
# Generate:  openssl rand -hex 64
SESSION_SECRET=change_me_to_a_64_char_or_longer_random_hex_string

# ── Node Environment ──────────────────────────────────────────────────────────
# Use "production" when deploying. Enables static frontend serving in the API server.
NODE_ENV=production

# ── Server Port ───────────────────────────────────────────────────────────────
# The port the API server listens on. Many hosts (incl. Hostinger Node.js apps)
# inject $PORT automatically — leave unset there. Set explicitly for local dev.
# PORT=8080

# ── Mobile App (Expo) ─────────────────────────────────────────────────────────
# The public hostname (no https://) used by the Expo bundle to reach the API.
# Set to your deployment domain after first deploy.
# Example:  myapp.example.com
EXPO_PUBLIC_DOMAIN=your-deploy-domain.example.com
