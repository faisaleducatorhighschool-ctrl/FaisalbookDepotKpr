modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "MySQL Database"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test"

[[workflows.workflow]]
name = "MySQL Database"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/start-mysql.sh"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm -r --if-present run test"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 4099
externalPort = 6800

[[ports]]
localPort = 4599
externalPort = 8008

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 7799
externalPort = 5000

[[ports]]
localPort = 7801
externalPort = 6000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 8080

[[ports]]
localPort = 8098
externalPort = 4200

[[ports]]
localPort = 8099
externalPort = 8099

[[ports]]
localPort = 23710
externalPort = 3003

[[ports]]
localPort = 24215
externalPort = 3000

[[ports]]
localPort = 24964
externalPort = 3001

[[ports]]
localPort = 25991
externalPort = 3002

[[ports]]
localPort = 25992
externalPort = 8000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.development]
MYSQL_URL = "mysql://root@127.0.0.1:3306/erp"
